# Required — PostgreSQL connection string
# On Railway: copy from your Railway Postgres service's connection URL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Required — port for the server to listen on
# Railway sets this automatically
PORT=3000

# Required for production — the public URL of your deployed app
# Example: https://weyn-emails.railway.app
# Used to build the correct webhook URL shown in the admin panel
VITE_PUBLIC_URL=https://your-app.railway.app

# Node environment
NODE_ENV=production
